#!/usr/bin/env bash

# Exit if no arguments provided
if [[ $# -eq 0 ]]; then
    echo "Usage: $0 <file.mp4> [file2.mp4 ...]" >&2
    exit 1
fi

for file in "$@"; do
    # Skip if not a regular file
    if [[ ! -f "$file" ]]; then
        echo "$file N/A (not found)"
        continue
    fi

    # Count frames using ffprobe
    # -v error: suppresses warnings/info
    # -count_frames: forces reading all frames to get an exact count
    # -select_streams v:0: targets the first video stream only
    # -show_entries stream=nb_read_frames: outputs only the frame count
    # -of default=noprint_wrappers=1:nokey=1: strips formatting, returns raw number
    count=$(ffprobe -v error -count_frames -select_streams v:0 \
        -show_entries stream=nb_read_frames \
        -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null)

    # Handle files with no video stream or ffprobe failures
    [[ -z "$count" ]] && count="N/A"

    echo "$file $count"
done

